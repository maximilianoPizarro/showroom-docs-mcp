{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "default": 1,
      "description": "Number of MCP server replicas"
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string",
          "default": "quay.io/maximilianopizarro/showroom-docs-mcp",
          "description": "Container image repository"
        },
        "tag": {
          "type": "string",
          "default": "latest",
          "description": "Container image tag"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"],
          "default": "Always",
          "description": "Image pull policy"
        }
      },
      "required": ["repository", "tag"]
    },
    "nameOverride": {
      "type": "string",
      "default": "",
      "description": "Override the chart name"
    },
    "fullnameOverride": {
      "type": "string",
      "default": "",
      "description": "Override the full release name"
    },
    "namespace": {
      "type": "string",
      "default": "openshift-lightspeed",
      "description": "Kubernetes namespace for deployment"
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"],
          "default": "ClusterIP",
          "description": "Kubernetes service type"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "default": 8080,
          "description": "Service port"
        }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "requests": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string",
              "default": "100m",
              "description": "CPU request"
            },
            "memory": {
              "type": "string",
              "default": "256Mi",
              "description": "Memory request"
            }
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string",
              "default": "500m",
              "description": "CPU limit"
            },
            "memory": {
              "type": "string",
              "default": "512Mi",
              "description": "Memory limit"
            }
          }
        }
      },
      "description": "Container resource requests and limits"
    },
    "readinessProbe": {
      "type": "object",
      "description": "Readiness probe configuration"
    },
    "livenessProbe": {
      "type": "object",
      "description": "Liveness probe configuration"
    },
    "nodeSelector": {
      "type": "object",
      "default": {},
      "description": "Node selector constraints"
    },
    "tolerations": {
      "type": "array",
      "default": [],
      "description": "Pod tolerations"
    },
    "affinity": {
      "type": "object",
      "default": {},
      "description": "Pod affinity rules"
    },
    "inspector": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable MCP Inspector deployment for testing tools"
        },
        "mcpServerUrl": {
          "type": "string",
          "default": "",
          "description": "Override MCP server URL for auto-connect (empty = auto-generated from chart values)"
        },
        "image": {
          "type": "object",
          "properties": {
            "repository": {
              "type": "string",
              "default": "mcpuse/inspector",
              "description": "MCP Inspector container image"
            },
            "tag": {
              "type": "string",
              "default": "latest",
              "description": "MCP Inspector image tag"
            },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"],
              "default": "IfNotPresent",
              "description": "Image pull policy"
            }
          }
        },
        "service": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["ClusterIP", "NodePort", "LoadBalancer"],
              "default": "ClusterIP",
              "description": "Inspector service type"
            },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535,
              "default": 8080,
              "description": "Inspector service port"
            }
          }
        },
        "route": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Create OpenShift Route for Inspector"
            },
            "timeout": {
              "type": "string",
              "default": "300s",
              "description": "HAProxy route timeout for long-lived MCP connections (prevents early disconnect)"
            },
            "tls": {
              "type": "object",
              "properties": {
                "termination": {
                  "type": "string",
                  "enum": ["edge", "passthrough", "reencrypt"],
                  "default": "edge",
                  "description": "TLS termination type"
                }
              }
            }
          }
        },
        "resources": {
          "type": "object",
          "properties": {
            "requests": {
              "type": "object",
              "properties": {
                "cpu": { "type": "string", "default": "50m" },
                "memory": { "type": "string", "default": "128Mi" }
              }
            },
            "limits": {
              "type": "object",
              "properties": {
                "cpu": { "type": "string", "default": "200m" },
                "memory": { "type": "string", "default": "256Mi" }
              }
            }
          },
          "description": "Inspector container resource requests and limits"
        }
      },
      "description": "MCP Inspector for testing tools without Lightspeed"
    },
    "litellm": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable LiteLLM proxy for OpenAI-compatible access to Granite models"
        },
        "image": {
          "type": "object",
          "properties": {
            "repository": {
              "type": "string",
              "default": "litellm/litellm-non_root",
              "description": "LiteLLM container image (non-root for OpenShift)"
            },
            "tag": {
              "type": "string",
              "default": "v1.82.3-stable",
              "description": "LiteLLM image tag"
            },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"],
              "default": "IfNotPresent",
              "description": "Image pull policy"
            }
          }
        },
        "service": {
          "type": "object",
          "properties": {
            "port": {
              "type": "integer",
              "default": 4000,
              "description": "LiteLLM service port"
            }
          }
        },
        "route": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Create OpenShift Route for LiteLLM"
            },
            "tls": {
              "type": "object",
              "properties": {
                "termination": {
                  "type": "string",
                  "enum": ["edge", "passthrough", "reencrypt"],
                  "default": "edge"
                }
              }
            }
          }
        },
        "masterKey": {
          "type": "string",
          "default": "sk-showroom-mcp-1234",
          "description": "Bearer token required to call the LiteLLM proxy"
        },
        "granite": {
          "type": "object",
          "properties": {
            "modelId": {
              "type": "string",
              "default": "isvc-granite-31-8b-fp8",
              "description": "vLLM model ID on the inference server"
            },
            "apiBase": {
              "type": "string",
              "default": "https://isvc-granite-31-8b-fp8-predictor.sandbox-shared-models.svc.cluster.local:8443/v1",
              "description": "Granite inference endpoint (internal cluster URL)"
            },
            "apiKey": {
              "type": "string",
              "default": "",
              "description": "Bearer token for Granite endpoint (use: --set litellm.granite.apiKey=$(oc whoami -t))"
            }
          },
          "description": "Granite model connection settings"
        },
        "postgres": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Enable PostgreSQL for LiteLLM dashboard (Red Hat RHEL9 image)"
            },
            "image": {
              "type": "object",
              "properties": {
                "repository": {
                  "type": "string",
                  "default": "registry.redhat.io/rhel9/postgresql-15"
                },
                "tag": {
                  "type": "string",
                  "default": "latest"
                }
              }
            },
            "user": {
              "type": "string",
              "default": "litellm",
              "description": "PostgreSQL username"
            },
            "password": {
              "type": "string",
              "default": "litellm",
              "description": "PostgreSQL password"
            },
            "database": {
              "type": "string",
              "default": "litellm",
              "description": "PostgreSQL database name"
            }
          },
          "description": "PostgreSQL database for LiteLLM dashboard (ephemeral storage)"
        },
        "resources": {
          "type": "object",
          "description": "LiteLLM container resource requests and limits"
        }
      },
      "description": "LiteLLM proxy for OpenAI-compatible access to internal Granite models (Developer Sandbox)"
    },
    "olsConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable automatic OLSConfig integration"
        },
        "mcpServerName": {
          "type": "string",
          "default": "showroom-docs-mcp",
          "description": "Name for the MCP server entry in OLSConfig"
        },
        "mcpServerTimeout": {
          "type": "integer",
          "minimum": 1,
          "default": 10,
          "description": "MCP server timeout in seconds"
        },
        "llm": {
          "type": "object",
          "properties": {
            "provider": {
              "type": "string",
              "default": "rhoai_vllm",
              "description": "LLM provider type (rhoai_vllm, watsonx, openai)"
            },
            "model": {
              "type": "string",
              "default": "granite-3-8b-instruct",
              "description": "LLM model name"
            },
            "url": {
              "type": "string",
              "default": "",
              "description": "LLM inference endpoint URL"
            },
            "credentialsSecret": {
              "type": "string",
              "default": "ols-llm-credentials",
              "description": "Secret name containing the API token"
            }
          },
          "description": "LLM configuration for OLSConfig"
        }
      },
      "description": "OLSConfig integration settings"
    }
  },
  "required": ["image", "service"]
}
